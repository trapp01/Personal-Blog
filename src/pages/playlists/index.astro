---
import SpotifyEmbed from "@/components/media/SpotifyEmbed.astro";
import PageLayout from "@/layouts/Base.astro";

interface FeaturedPlaylist {
	title: string;
	url: string;
}

// Playlists I want to highlight — replace these with your own "Top 10 of YYYY" share links.
const playlists: FeaturedPlaylist[] = [
	{
		title: "Today's Top Hits (example — replace me)",
		url: "https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M",
	},
];

const meta = {
	description: "Playlists I keep coming back to.",
	title: "Playlists",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-3">Playlists</h1>
	<p class="text-muted mb-10">A few playlists I keep coming back to.</p>
	{
		playlists.length === 0 ? (
			<p class="text-muted">No playlists yet.</p>
		) : (
			<div class="grid gap-4 sm:grid-cols-2">
				{playlists.map((playlist) => (
					<SpotifyEmbed title={playlist.title} url={playlist.url} />
				))}
			</div>
		)
	}
</PageLayout>
