---
import { getAllMedia } from "@/data/media";
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const [allPosts, allMedia] = await Promise.all([getAllPosts(), getAllMedia()]);
const allTags = getUniqueTagsWithCount([...allPosts, ...allMedia]);

const meta = {
	description: "A list of all the topics across my posts and shelf",
	title: "All Tags",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">Tags</h1>
	<ul class="space-y-4">
		{
			allTags.map(([tag, val]) => (
				<li class="flex items-center gap-x-2">
					<a
						class="cactus-link inline-block"
						href={`/tags/${tag}/`}
						title={`View everything tagged: ${tag}`}
					>
						&#35;{tag}
					</a>
					<span class="inline-block">
						- {val} item{val > 1 && "s"}
					</span>
				</li>
			))
		}
	</ul>
</PageLayout>
