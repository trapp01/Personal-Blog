---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import Rating from "@/components/media/Rating.astro";
import { MEDIA_TYPES } from "@/data/media";

interface Props {
	item: CollectionEntry<"media">;
	class?: string;
}

const { class: className, item } = Astro.props;
const { type, coverImage, creator, publishDate, rating, title } = item.data;
const typeMeta = MEDIA_TYPES[type];
---

<article
	class:list={["media-card group", className]}
	data-type={type}
	data-date={publishDate.getTime()}
	data-rating={rating}
>
	<a class="block" href={`/shelf/${item.id}/`}>
		<div class="bg-global-text/5 relative mb-2 aspect-square overflow-hidden rounded-lg">
			{
				coverImage ? (
					<Image
						alt={coverImage.alt}
						class="h-full w-full object-cover transition-transform group-hover:scale-105"
						height={300}
						src={coverImage.src}
						width={300}
					/>
				) : (
					<span class="text-muted absolute inset-0 flex items-center justify-center">
						<Icon name={typeMeta.icon} class="h-10 w-10" aria-hidden="true" />
					</span>
				)
			}
			<span
				class="bg-global-bg/80 text-muted absolute end-1.5 top-1.5 rounded px-1.5 py-0.5 text-xs font-semibold backdrop-blur"
			>
				{typeMeta.label}
			</span>
		</div>
		<h3 class="group-hover:text-link line-clamp-2 leading-snug font-semibold">{title}</h3>
	</a>
	<p class="text-muted truncate text-sm">{creator}</p>
	<Rating class="mt-1" rating={rating} />
</article>
